{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "out/renderer",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@shared": ["src/shared/index.ts"],
      "@shared/*": ["src/shared/*"],
      "@db": ["src/db/index.ts"],
      "@db/*": ["src/db/*"]
    }
  },
  "include": ["src/renderer/**/*"],
  "exclude": ["node_modules", "out", "dist"]
}
