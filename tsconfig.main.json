{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "outDir": "out/main",
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@shared": ["src/shared/index.ts"],
      "@shared/*": ["src/shared/*"],
      "@db": ["src/db/index.ts"],
      "@db/*": ["src/db/*"]
    }
  },
  "include": ["src/main/**/*", "src/shared/**/*", "src/db/**/*"],
  "exclude": ["node_modules", "out", "dist"]
}
