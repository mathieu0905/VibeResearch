generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "windows", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Paper {
  id                   String     @id @default(cuid())
  shortId              String     @unique
  title                String
  authorsJson          String     @default("[]")
  source               SourceType
  sourceUrl            String?
  submittedAt          DateTime?
  abstract             String?
  pdfUrl               String?
  pdfPath              String?
  textPath             String? // Path to local text.txt file (papers/{shortId}/text.txt)
  processingStatus     String     @default("idle")
  processingError      String?
  processedAt          DateTime?
  indexedAt            DateTime?
  metadataSource       String?
  rating               Int?
  doi                  String?
  venue                String?    // Journal, conference, or publication venue name
  citationsExtractedAt DateTime?
  isTemporary          Boolean    @default(false) // Imported temporarily from Discovery
  temporaryImportedAt  DateTime?             // When the paper was temporarily imported
  lastReadPage         Int?
  totalPages           Int?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  lastReadAt           DateTime?

  events        SourceEvent[]
  tags          PaperTag[]
  embedding     PaperEmbedding?
  readingNotes  ReadingNote[]
  highlights    PaperHighlight[]
  links         PaperCodeLink[]
  projects      ProjectPaper[]
  citationsFrom PaperCitation[]   @relation("CitesFrom")
  citedBy       PaperCitation[]   @relation("CitedBy")
  extractedRefs ExtractedReference[]
  agentTodos    AgentTodo[]

  @@index([shortId])
  @@index([title])
  @@index([submittedAt])
  @@index([source])
  @@index([processingStatus])
  @@index([doi])
  @@index([lastReadAt])
}

model PaperEmbedding {
  id                String   @id @default(cuid())
  paperId           String   @unique
  titleEmbedding    String?
  abstractEmbedding String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
}

model SourceEvent {
  id         String     @id @default(cuid())
  paperId    String
  source     SourceType
  rawTitle   String?
  rawUrl     String?
  importedAt DateTime   @default(now())

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([source])
  @@index([importedAt])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String   @default("topic")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  papers PaperTag[]

  @@index([name])
  @@index([category])
}

model PaperTag {
  paperId String
  tagId   String

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([paperId, tagId])
  @@index([tagId])
}

model PaperHighlight {
  id         String   @id @default(cuid())
  paperId    String
  pageNumber Int
  rectsJson  String // [{x, y, w, h}] normalized to 0-1 page coords
  text       String // selected text content
  note       String? // legacy single note (migrated to notes JSON array)
  aiNote     String? // AI-generated annotation note
  notes      String  @default("[]") // JSON array of { id, text, createdAt }
  color      String  @default("yellow") // yellow|green|blue|pink|purple
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([pageNumber])
}

model ReadingNote {
  id          String          @id @default(cuid())
  paperId     String?
  type        ReadingNoteType
  title       String
  contentJson String
  version     Int             @default(1)
  repoUrl     String?
  commitHash  String?
  // Link to the Chat session this note was generated from (one-to-one)
  chatNoteId  String?         @unique
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  paper          Paper?       @relation(fields: [paperId], references: [id], onDelete: SetNull)
  // The Chat session this note was generated from
  chatSession    ReadingNote? @relation("ChatToNotes", fields: [chatNoteId], references: [id], onDelete: SetNull)
  // Notes generated from this Chat session (if this is a Chat)
  generatedNotes ReadingNote? @relation("ChatToNotes")

  @@index([type])
  @@index([paperId])
  @@index([chatNoteId])
}

model Project {
  id              String    @id @default(cuid())
  name            String
  description     String?
  workdir         String?
  sshServerId     String?   // SSH server ID (reference to JSON store)
  remoteWorkdir   String?   // Remote working directory when using SSH
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastAccessedAt  DateTime?

  repos   ProjectRepo[]
  ideas   ProjectIdea[]
  todos   AgentTodo[]
  papers  ProjectPaper[]
  experimentReports ExperimentReport[]
  taskResults TaskResult[]
  chats   ChatSession[]

  @@index([name])
  @@index([lastAccessedAt])
}

model ProjectRepo {
  id            String    @id @default(cuid())
  projectId     String
  repoUrl       String
  localPath     String?
  clonedAt      DateTime?
  isWorkdirRepo Boolean   @default(false) // True if this repo is the project's workdir (no clone needed)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectIdea {
  id           String   @id @default(cuid())
  projectId    String
  title        String
  content      String
  paperIdsJson String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model PaperCodeLink {
  id         String   @id @default(cuid())
  paperId    String
  repoUrl    String
  commitHash String?
  confidence Float    @default(0.5)
  source     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([repoUrl])
}

model ProjectPaper {
  id        String   @id @default(cuid())
  projectId String
  paperId   String
  addedAt   DateTime @default(now())
  note      String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  paper   Paper   @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@unique([projectId, paperId])
  @@index([projectId])
}

enum SourceType {
  chrome
  manual
  arxiv
  zotero
  doi
  bibtex
  overleaf
}

enum ReadingNoteType {
  paper
  code
}

model AgentConfig {
  id            String   @id @default(uuid())
  name          String
  backend       String
  cliPath       String?
  acpArgs       String   @default("[]")
  agentTool     String? // 'claude-code' | 'codex'
  configContent String? // Config file content (JSON/TOML)
  authContent   String? // Auth file content
  apiKey        String? // API key for Code X
  baseUrl       String? // Base URL for Code X
  isDetected    Boolean  @default(false)
  isCustom      Boolean  @default(false)
  enabled       Boolean  @default(true)
  extraEnv      String   @default("{}")
  // Remote SSH execution fields
  isRemote               Boolean  @default(false)
  sshHost                String?
  sshPort                Int?
  sshUsername            String?
  sshAuthMethod          String?  // 'password' | 'privateKey'
  sshPrivateKeyPath      String?
  sshPassphraseEncrypted String?  // encrypted via safeStorage
  remoteCliPath          String?  // full path to CLI on remote server
  remoteExtraEnv         String   @default("{}") // extra env for remote (e.g. PATH overrides)
  defaultModel  String?
  callCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  todos AgentTodo[]
}

model AgentTodo {
  id          String      @id @default(uuid())
  title       String
  prompt      String
  cwd         String
  agentId     String
  agent       AgentConfig @relation(fields: [agentId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  paperId     String?
  paper       Paper?      @relation(fields: [paperId], references: [id], onDelete: SetNull)
  status      String      @default("idle")
  priority    Int         @default(0)
  cronExpr    String?
  cronEnabled Boolean     @default(false)
  yoloMode    Boolean     @default(false)
  model       String?
  outputDir   String?
  sessionId   String?
  lastRunId   String?
  lastRunAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  runs AgentTodoRun[]
  results TaskResult[]
}

model AgentTodoRun {
  id           String    @id @default(uuid())
  todoId       String
  todo         AgentTodo @relation(fields: [todoId], references: [id], onDelete: Cascade)
  status       String    @default("pending")
  trigger      String    @default("manual")
  sessionId    String?
  startedAt    DateTime?
  finishedAt   DateTime?
  exitCode     Int?
  errorMessage String?
  summary      String?
  tokenUsage   String?
  createdAt    DateTime  @default(now())

  messages AgentTodoMessage[]
}

model AgentTodoMessage {
  id         String       @id @default(uuid())
  runId      String
  run        AgentTodoRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  msgId      String
  type       String
  role       String       @default("assistant")
  content    String
  status     String?
  toolCallId String?
  toolName   String?
  createdAt  DateTime     @default(now())

  @@index([runId])
  @@index([msgId])
}

model PaperCitation {
  id            String   @id @default(cuid())
  sourcePaperId String
  targetPaperId String?
  externalTitle String?
  externalId    String?
  citationType  String   @default("reference")
  context       String?
  confidence    Float    @default(1.0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sourcePaper Paper  @relation("CitesFrom", fields: [sourcePaperId], references: [id], onDelete: Cascade)
  targetPaper Paper? @relation("CitedBy", fields: [targetPaperId], references: [id], onDelete: SetNull)

  @@unique([sourcePaperId, externalId])
  @@index([sourcePaperId])
  @@index([targetPaperId])
}

// Extracted reference from PDF (cached)
model ExtractedReference {
  id            String   @id @default(cuid())
  paperId       String
  refNumber     Int      // Reference number in the paper (1, 2, 3...)
  text          String   // Full reference text
  title         String?
  authors       String?
  year          Int?
  doi           String?
  arxivId       String?
  url           String?
  venue         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@unique([paperId, refNumber])
  @@index([paperId])
  @@index([doi])
  @@index([arxivId])
}

model ExperimentReport {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String
  content       String
  summary       String?
  todoIdsJson   String   @default("[]")
  resultIdsJson String   @default("[]")
  modelUsed     String?
  version       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
  @@index([createdAt])
}

model TaskResult {
  id            String    @id @default(cuid())
  todoId        String
  todo          AgentTodo @relation(fields: [todoId], references: [id], onDelete: Cascade)
  runId         String?
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  relativePath  String
  fileName      String
  fileType      String
  mimeType      String?
  sizeBytes     Int?
  title         String?
  description   String?
  tagsJson      String    @default("[]")
  generatedBy   String    @default("agent")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([todoId])
  @@index([projectId])
  @@index([runId])
  @@index([fileType])
  @@index([createdAt])
}

model ChatSession {
  id           String        @id @default(cuid())
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  paperIdsJson String        @default("[]")
  repoIdsJson  String        @default("[]")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // ACP-specific fields (nullable for backward compat)
  backend        String?  // 'lightweight' | 'claude-code' | 'codex' | 'gemini' | 'opencode' | null
  acpSessionId   String?  // ACP protocol session ID for resume
  sessionMode    String?  // 'default' | 'bypassPermissions'
  currentModelId String?  // Active model
  cwd            String?  // Working directory

  messages ChatMessage[]

  @@index([projectId])
  @@index([createdAt])
  @@index([backend])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // 'user' | 'assistant' | 'thought' | 'tool_call' | 'permission'
  content   String
  createdAt DateTime    @default(now())

  // ACP metadata (store as JSON)
  metadataJson String @default("{}")
  // Examples:
  // - thought: { type: 'thought' }
  // - tool_call: { toolCallId, status, title, kind, rawInput, content }
  // - permission: { requestId, options, toolCall }

  @@index([sessionId])
  @@index([createdAt])
}
