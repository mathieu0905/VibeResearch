generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "windows", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Paper {
  id          String          @id @default(cuid())
  shortId     String          @unique
  title       String
  authorsJson String          @default("[]")
  source      SourceType
  sourceUrl   String?
  submittedAt DateTime?
  abstract    String?
  pdfUrl      String?
  pdfPath     String?
  textPath    String?         // Path to local text.txt file (papers/{shortId}/text.txt)
  processingStatus String     @default("idle")
  processingError  String?
  processedAt      DateTime?
  indexedAt        DateTime?
  metadataSource   String?
  rating      Int?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lastReadAt  DateTime?

  events      SourceEvent[]
  tags        PaperTag[]
  chunks      PaperChunk[]
  readingNotes ReadingNote[]
  links       PaperCodeLink[]
  collections PaperCollection[]

  @@index([shortId])
  @@index([title])
  @@index([submittedAt])
  @@index([source])
  @@index([processingStatus])
}

model PaperChunk {
  id             String   @id @default(cuid())
  paperId        String
  chunkIndex     Int
  content        String
  contentPreview String
  embeddingJson  String
  createdAt      DateTime @default(now())

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@unique([paperId, chunkIndex])
}

model SourceEvent {
  id         String   @id @default(cuid())
  paperId     String
  source      SourceType
  rawTitle    String?
  rawUrl      String?
  importedAt  DateTime @default(now())

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([source])
  @@index([importedAt])
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  category  String    @default("topic")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  papers    PaperTag[]

  @@index([name])
  @@index([category])
}

model PaperTag {
  paperId String
  tagId   String

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([paperId, tagId])
  @@index([tagId])
}

model ReadingNote {
  id         String          @id @default(cuid())
  paperId     String?
  type       ReadingNoteType
  title      String
  contentJson String
  version    Int             @default(1)
  repoUrl    String?
  commitHash String?
  // Link to the Chat session this note was generated from (one-to-one)
  chatNoteId String?         @unique
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  paper Paper? @relation(fields: [paperId], references: [id], onDelete: SetNull)
  // The Chat session this note was generated from
  chatSession ReadingNote?  @relation("ChatToNotes", fields: [chatNoteId], references: [id], onDelete: SetNull)
  // Notes generated from this Chat session (if this is a Chat)
  generatedNotes ReadingNote? @relation("ChatToNotes")

  @@index([type])
  @@index([paperId])
  @@index([chatNoteId])
}

model Project {
  id              String    @id @default(cuid())
  name            String
  description     String?
  workdir         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastAccessedAt  DateTime?

  repos  ProjectRepo[]
  ideas  ProjectIdea[]
  todos  AgentTodo[]

  @@index([name])
  @@index([lastAccessedAt])
}

model ProjectRepo {
  id            String   @id @default(cuid())
  projectId     String
  repoUrl       String
  localPath     String?
  clonedAt      DateTime?
  isWorkdirRepo Boolean  @default(false) // True if this repo is the project's workdir (no clone needed)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectIdea {
  id             String   @id @default(cuid())
  projectId      String
  title          String
  content        String
  paperIdsJson   String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model PaperCodeLink {
  id         String   @id @default(cuid())
  paperId    String
  repoUrl    String
  commitHash String?
  confidence Float    @default(0.5)
  source     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([repoUrl])
}

model Collection {
  id          String            @id @default(cuid())
  name        String            @unique
  icon        String?
  color       String?
  description String?
  isDefault   Boolean           @default(false)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  papers      PaperCollection[]

  @@index([sortOrder])
}

model PaperCollection {
  paperId      String
  collectionId String
  addedAt      DateTime   @default(now())

  paper      Paper      @relation(fields: [paperId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([paperId, collectionId])
  @@index([collectionId])
}

enum SourceType {
  chrome
  manual
  arxiv
}

enum ReadingNoteType {
  paper
  code
}

model AgentConfig {
  id            String   @id @default(uuid())
  name          String
  backend       String
  cliPath       String?
  acpArgs       String   @default("[]")
  agentTool     String?  // 'claude-code' | 'codex'
  configContent String?  // Config file content (JSON/TOML)
  authContent   String?  // Auth file content
  apiKey        String?  // API key for Code X
  baseUrl       String?  // Base URL for Code X
  isDetected    Boolean  @default(false)
  isCustom      Boolean  @default(false)
  enabled       Boolean  @default(true)
  extraEnv      String   @default("{}")
  defaultModel  String?
  callCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  todos         AgentTodo[]
}

model AgentTodo {
  id            String   @id @default(uuid())
  title         String
  prompt        String
  cwd           String
  agentId       String
  agent         AgentConfig @relation(fields: [agentId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status        String   @default("idle")
  priority      Int      @default(0)
  cronExpr      String?
  cronEnabled   Boolean  @default(false)
  yoloMode      Boolean  @default(false)
  model         String?
  sessionId     String?
  lastRunId     String?
  lastRunAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  runs          AgentTodoRun[]
}

model AgentTodoRun {
  id            String   @id @default(uuid())
  todoId        String
  todo          AgentTodo @relation(fields: [todoId], references: [id], onDelete: Cascade)
  status        String   @default("pending")
  trigger       String   @default("manual")
  sessionId     String?
  startedAt     DateTime?
  finishedAt    DateTime?
  exitCode      Int?
  errorMessage  String?
  summary       String?
  tokenUsage    String?
  createdAt     DateTime @default(now())

  messages      AgentTodoMessage[]
}

model AgentTodoMessage {
  id            String   @id @default(uuid())
  runId         String
  run           AgentTodoRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  msgId         String
  type          String
  role          String   @default("assistant")
  content       String
  status        String?
  toolCallId    String?
  toolName      String?
  createdAt     DateTime @default(now())

  @@index([runId])
  @@index([msgId])
}
