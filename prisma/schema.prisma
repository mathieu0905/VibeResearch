generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "windows", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Paper {
  id          String          @id @default(cuid())
  shortId     String          @unique
  title       String
  authorsJson String          @default("[]")
  source      SourceType
  sourceUrl   String?
  year        Int?
  abstract    String?
  pdfUrl      String?
  pdfPath     String?
  textPath    String?         // Path to local text.txt file (papers/{shortId}/text.txt)
  rating      Int?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lastReadAt  DateTime?

  events      SourceEvent[]
  tags        PaperTag[]
  readingNotes ReadingNote[]
  links       PaperCodeLink[]

  @@index([shortId])
  @@index([title])
  @@index([year])
  @@index([source])
}

model SourceEvent {
  id         String   @id @default(cuid())
  paperId     String
  source      SourceType
  rawTitle    String?
  rawUrl      String?
  importedAt  DateTime @default(now())

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([source])
  @@index([importedAt])
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  category  String    @default("topic")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  papers    PaperTag[]

  @@index([name])
  @@index([category])
}

model PaperTag {
  paperId String
  tagId   String

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([paperId, tagId])
  @@index([tagId])
}

model ReadingNote {
  id         String          @id @default(cuid())
  paperId     String?
  type       ReadingNoteType
  title      String
  contentJson String
  version    Int             @default(1)
  repoUrl    String?
  commitHash String?
  // Link to the Chat session this note was generated from (one-to-one)
  chatNoteId String?         @unique
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  paper Paper? @relation(fields: [paperId], references: [id], onDelete: SetNull)
  // The Chat session this note was generated from
  chatSession ReadingNote?  @relation("ChatToNotes", fields: [chatNoteId], references: [id], onDelete: SetNull)
  // Notes generated from this Chat session (if this is a Chat)
  generatedNotes ReadingNote? @relation("ChatToNotes")

  @@index([type])
  @@index([paperId])
  @@index([chatNoteId])
}

model Project {
  id              String    @id @default(cuid())
  name            String
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastAccessedAt  DateTime?

  todos  ProjectTodo[]
  repos  ProjectRepo[]
  ideas  ProjectIdea[]

  @@index([name])
  @@index([lastAccessedAt])
}

model ProjectTodo {
  id          String   @id @default(cuid())
  projectId   String
  text        String
  done        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectRepo {
  id          String   @id @default(cuid())
  projectId   String
  repoUrl     String
  localPath   String?
  clonedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectIdea {
  id             String   @id @default(cuid())
  projectId      String
  title          String
  content        String
  paperIdsJson   String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model PaperCodeLink {
  id         String   @id @default(cuid())
  paperId    String
  repoUrl    String
  commitHash String?
  confidence Float    @default(0.5)
  source     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([repoUrl])
}

enum SourceType {
  chrome
  manual
  arxiv
}

enum ReadingNoteType {
  paper
  code
}
